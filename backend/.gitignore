# pyenv
#   For a library or app, you might want to share your .python-version.
#   It makes pyenv switch to the local version automatically.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different OS, they may get conflicts.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains exact versions, but can be sometimes skipped.
# poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains exact versions
pdm.lock
#   pdm local configuration
.pdm-python.path
.pdm-build/

