        }
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "id": 4,
      "options": {
        "legend": {
          "calcs": ["sum"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "sum(rate(http_requests_total{job=\"fastapi\"}[1m])) by (status)",
          "legendFormat": "HTTP Status {{status}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "HTTP Status Codes Rate",
      "type": "timeseries"
    },
    {
